Check B — Confirm the model exists from the registry’s point of view (authoritative)
from mlflow.tracking import MlflowClient
c = MlflowClient()

# does the registry see it?
names = [m.name for m in c.search_registered_models()]
print("found?", "irish_home_reg_B" in names)

# does it have versions?
vers = c.search_model_versions("name='irish_home_reg_B'")
print([(v.version, v.status, v.current_stage) for v in vers])

